NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# MySQL connection — individual values
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=salon

# Prisma needs a single DATABASE_URL. Keep this in sync with the values above.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://root:rootpassword@localhost:3306/salon

JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-another-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMS Configuration (Notify.lk)
SMS_USER_ID=
SMS_API_KEY=
SMS_SENDER_ID=

# Optional: prisma db seed — defaults create superadmin@gmail.com / Admin@123
# SUPERADMIN_EMAIL=superadmin@gmail.com
# SUPERADMIN_PASSWORD=Admin@123
